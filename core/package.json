{
  "name": "postfolio",
  "version": "1.0.5",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./renderer": {
      "types": "./dist/src/renderer.d.ts",
      "import": "./dist/src/renderer.js"
    },
    "./client": {
      "types": "./dist/src/client.d.ts",
      "import": "./dist/src/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "esbuild": "^0.28.0",
    "gray-matter": "^4.0.3",
    "mdx-bundler": "^10.1.1",
    "server-only": "^0.0.1"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "tsup": "^8.5.1",
    "typescript": "^5"
  },
  "allowScripts": {
    "esbuild@0.27.7": true
  }
}
