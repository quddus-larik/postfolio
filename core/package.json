{
  "name": "postfolio",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./renderer": {
      "types": "./dist/src/renderer.d.ts",
      "import": "./dist/src/renderer.js"
    },
    "./client": {
      "types": "./dist/src/client.d.ts",
      "import": "./dist/src/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "mdx-bundler": "^10.1.1"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "typescript": "^5"
  },
  "allowScripts": {
    "esbuild@0.27.7": true
  }
}
